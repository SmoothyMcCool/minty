// --- Determine column headers ---
- var firstRow = null
if data != null && data.size() > 0
  - firstRow = data.get(0)

// --- Safe HTML cell renderer ---
mixin safeCell(val)
  - var safe = helpers.tryMakeSafe(val)
  if safe != null
    td !{safe}
  else if val != null
    td #{val}
  else
    td

// --- Pre-pass: count renderable rows ---
- var len = helpers.max(text != null ? text.size() : 0, data != null ? data.size() : 0)
- var totalRows = 0
- var i = 0
while i < len
  - var t = (text != null && i < text.size()) ? text.get(i) : null
  - var d = (data != null && i < data.size()) ? data.get(i) : null
  - var shouldRender = helpers.isNotBlank(t) || (d != null && (firstRow == null || helpers.hasAnyValueForKeys(d, firstRow.keySet())))
  if shouldRender
    - totalRows = totalRows + 1
  - i = i + 1

p.text-muted.mb-2 #{totalRows} Items

table.table.table-hover.table-sm
  thead
    tr
      th(scope="col") #
      th(scope="col") Text
      if firstRow != null
        each entry in firstRow.entrySet()
          th(scope="col") #{entry.getKey()}

  tbody
    - var rowIdx = 0
    - i = 0
    while i < len
      - var t = (text != null && i < text.size()) ? text.get(i) : null
      - var d = (data != null && i < data.size()) ? data.get(i) : null
      - var shouldRender = helpers.isNotBlank(t) || (d != null && (firstRow == null || helpers.hasAnyValueForKeys(d, firstRow.keySet())))
      if shouldRender
        - rowIdx = rowIdx + 1
        tr
          td #{rowIdx}
          +safeCell(t)
          if firstRow != null && d != null
            each entry in firstRow.entrySet()
              - var key = entry.getKey()
              - var val = d.get(key)
              +safeCell(val)
          else if firstRow != null
            each entry in firstRow.entrySet()
              td
      - i = i + 1